<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>零件庫存智慧查詢系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen">
    <div class="max-w-md mx-auto min-h-screen flex flex-col bg-white shadow-2xl relative">
        <header class="bg-slate-900 p-6 sticky top-0 z-30 shadow-md">
            <div class="flex justify-between items-center mb-4">
                <h1 class="text-white font-bold text-lg">📦 雲端零件檢索</h1>
                <div id="syncBadge" class="text-[10px] text-slate-400 border border-slate-700 px-2 py-1 rounded-full">同步中...</div>
            </div>
            <div class="relative">
                <input type="text" id="filterInput" oninput="runFilter()" 
                       placeholder="搜尋料號或規格..." 
                       class="w-full p-4 pl-12 rounded-2xl bg-slate-800 text-white border-none focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                <span class="absolute left-4 top-4 text-xl">🔍</span>
            </div>
        </header>

        <main id="itemList" class="flex-1 p-4 space-y-4 overflow-y-auto bg-slate-50">
            <div id="loadingInfo" class="text-center py-20 text-slate-400 italic">正在從 Google Sheet 抓取資料...</div>
        </main>
    </div>

    <script>
        // ==========================================
        //  https://hsuehung0518-chen.github.io/CERTEXTRAPART/
        // ==========================================
        const SHEET_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vRNTdZpaHZ0QrhSEdL4aBHTraHZ7kf-cpi8SLIayDzAr2Dke7u50wqDSadAkwaTkXBsg8hnJfv-B5Gf/pub?output=csv";

        let db = [];

        async function loadData() {
            const listEl = document.getElementById('itemList');
            const badge = document.getElementById('syncBadge');

            try {
                let fetchUrl = SHEET_URL;
                if (SHEET_URL.includes("pubhtml")) {
                    fetchUrl = SHEET_URL.replace("pubhtml", "pub?output=csv");
                } else if (!SHEET_URL.includes("output=csv")) {
                    fetchUrl = SHEET_URL + (SHEET_URL.includes("?") ? "&" : "?") + "output=csv";
                }

                // 加上時間戳防止快取舊資料
                fetchUrl += "&cachebust=" + new Date().getTime();

                const response = await fetch(fetchUrl);
                if (!response.ok) throw new Error("Google Sheet 未能正確回應");
                
                const csvData = await response.text();
                // 處理 CSV 換行與逗號
                const rows = csvData.split(/\r?\n/).filter(row => row.trim() !== "").map(row => {
                    return row.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/);
                });

                if (rows.length < 2) throw new Error("表格內無有效資料");

                // --- 策略變更：不再找名稱，直接按 A, B, C, D 順序映射 ---
                db = rows.slice(1).map(row => {
                    return {
                        name: (row[0] || "").replace(/"/g, "").trim(), // 第一欄：料號
                        spec: (row[1] || "").replace(/"/g, "").trim(), // 第二欄：規格
                        photo: (row[2] || "").replace(/"/g, "").trim(), // 第三欄：照片
                        qty: (row[3] || "0").replace(/"/g, "").trim()   // 第四欄：數量
                    };
                }).filter(i => i.name !== "");

                badge.innerText = `已載入 ${db.length} 筆`;
                runFilter();

            } catch (e) {
                badge.innerText = "連線異常";
                listEl.innerHTML = `
                    <div class="p-10 text-center bg-red-50 rounded-3xl m-4 border border-red-100">
                        <p class="text-red-600 font-bold mb-2">無法讀取資料</p>
                        <p class="text-[10px] text-red-400 leading-relaxed">${e.message}</p>
                        <button onclick="location.reload()" class="mt-4 px-6 py-2 bg-red-600 text-white rounded-full text-xs">手動重新整理</button>
                    </div>`;
            }
        }

        function runFilter() {
            const term = document.getElementById('filterInput').value.toLowerCase();
            const listEl = document.getElementById('itemList');
            const results = db.filter(i => i.name.toLowerCase().includes(term) || i.spec.toLowerCase().includes(term));

            if (results.length === 0) {
                listEl.innerHTML = `<div class="text-center py-20 text-slate-400 text-sm">查無符合的資料</div>`;
                return;
            }

            listEl.innerHTML = results.map(i => `
                <div class="bg-white rounded-3xl overflow-hidden shadow-sm border border-slate-100 mb-4">
                    ${i.photo && i.photo.startsWith('http') ? 
                        `<div class="w-full h-48 bg-slate-200 overflow-hidden">
                            <img src="${i.photo}" class="w-full h-full object-cover" onerror="this.parentNode.style.display='none'">
                        </div>` : ''
                    }
                    <div class="p-5">
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex-1 pr-4">
                                <h3 class="font-black text-slate-800 text-lg leading-tight mb-2">${i.name}</h3>
                                <span class="bg-blue-50 text-blue-600 text-[10px] font-bold px-3 py-1 rounded-full uppercase">料號名稱</span>
                            </div>
                            <div class="text-right">
                                <span class="text-3xl font-black ${parseInt(i.qty) <= 0 ? 'text-red-500' : 'text-slate-900'}">${i.qty}</span>
                                <p class="text-[8px] text-slate-400 font-bold uppercase tracking-widest">在庫數量</p>
                            </div>
                        </div>
                        <div class="pt-4 border-t border-slate-50">
                            <p class="text-[10px] text-slate-400 font-bold mb-2 uppercase tracking-tighter italic">Specification</p>
                            <p class="text-sm text-slate-600 leading-snug font-medium">${i.spec}</p>
                        </div>
                    </div>
                </div>
            `).join('');
        }
        window.onload = loadData;
    </script>
</body>
</html>
