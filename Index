<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>零件庫存智慧查詢系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen">
    <div class="max-w-md mx-auto min-h-screen flex flex-col bg-white shadow-2xl relative">
        <header class="bg-slate-900 p-6 sticky top-0 z-30 shadow-md">
            <div class="flex justify-between items-center mb-4">
                <h1 class="text-white font-bold text-lg">📦 雲端零件檢索</h1>
                <div id="syncBadge" class="text-[10px] text-slate-400 border border-slate-700 px-2 py-1 rounded-full">同步中...</div>
            </div>
            <div class="relative">
                <input type="text" id="filterInput" oninput="runFilter()" 
                       placeholder="輸入名稱、規格或儲位搜尋..." 
                       class="w-full p-4 pl-12 rounded-2xl bg-slate-800 text-white border-none focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                <span class="absolute left-4 top-4 opacity-40">🔍</span>
            </div>
        </header>

        <main id="itemList" class="flex-1 p-4 space-y-4 overflow-y-auto bg-slate-50">
            <div class="text-center py-20 text-slate-400 italic">正在連接 Google Sheet 資料庫...</div>
        </main>
    </div>

    <script>
        // --- 設定：請在此貼入你的 Google Sheet 發佈網址 ---
        const SHEET_URL = "在此貼入你的Google_Sheet發佈網址";
        // ----------------------------------------------

        let db = [];
        let headers = {};

        async function loadData() {
            try {
                const csvUrl = SHEET_URL.replace(/\/pubhtml.*/, "/pub?output=csv");
                const response = await fetch(csvUrl);
                const text = await response.text();
                
                // 解析 CSV 並處理括號內的逗號 (CSV 標準處理)
                const rows = text.split(/\r?\n/).map(row => row.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/));
                if (rows.length < 1) return;

                // 動態搜尋標題索引
                const firstRow = rows[0].map(h => h.replace(/"/g, "").trim());
                headers = {
                    name: firstRow.findIndex(h => h.includes("名稱") || h.includes("零件")),
                    qty: firstRow.findIndex(h => h.includes("數量") || h.includes("庫存")),
                    spec: firstRow.findIndex(h => h.includes("規格") || h.includes("描述")),
                    loc: firstRow.findIndex(h => h.includes("位置") || h.includes("儲位")),
                    photo: firstRow.findIndex(h => h.includes("照片") || h.includes("圖片"))
                };

                db = rows.slice(1).map(row => ({
                    name: row[headers.name]?.replace(/"/g, "") || "",
                    qty: row[headers.qty]?.replace(/"/g, "") || "0",
                    spec: row[headers.spec]?.replace(/"/g, "") || "-",
                    loc: row[headers.loc]?.replace(/"/g, "") || "-",
                    photo: row[headers.photo]?.replace(/"/g, "") || ""
                })).filter(i => i.name !== "");

                document.getElementById('syncBadge').innerText = `已載入 ${db.length} 筆`;
                runFilter();
            } catch (e) {
                document.getElementById('itemList').innerHTML = `<div class="p-10 text-red-500 text-center text-sm">讀取失敗，請確認發佈設定。</div>`;
            }
        }

        function runFilter() {
            const term = document.getElementById('filterInput').value.toLowerCase();
            const listEl = document.getElementById('itemList');
            
            const results = db.filter(i => 
                i.name.toLowerCase().includes(term) || 
                i.spec.toLowerCase().includes(term) || 
                i.loc.toLowerCase().includes(term)
            );

            if (results.length === 0) {
                listEl.innerHTML = `<div class="text-center py-20 text-slate-400 text-sm">查無符合條件的零件</div>`;
                return;
            }

            listEl.innerHTML = results.map(i => `
                <div class="bg-white rounded-3xl overflow-hidden shadow-sm border border-slate-100 flex flex-col">
                    ${i.photo && i.photo.startsWith('http') ? 
                        `<div class="w-full h-40 bg-slate-200 overflow-hidden">
                            <img src="${i.photo}" class="w-full h-full object-cover" onerror="this.src='https://via.placeholder.com/400x200?text=Image+Error'">
                        </div>` : ''
                    }
                    <div class="p-5">
                        <div class="flex justify-between items-start">
                            <div class="flex-1 pr-4">
                                <h3 class="font-black text-slate-800 text-lg leading-tight mb-1">${i.name}</h3>
                                <p class="text-[10px] font-bold text-blue-500 uppercase tracking-widest">儲位: ${i.loc}</p>
                            </div>
                            <div class="text-right">
                                <span class="text-3xl font-black ${parseInt(i.qty) < 5 ? 'text-red-500' : 'text-slate-900'}">${i.qty}</span>
                                <p class="text-[8px] text-slate-400 font-bold uppercase">In Stock</p>
                            </div>
                        </div>
                        <div class="mt-4 pt-4 border-t border-slate-50">
                            <p class="text-[11px] text-slate-400 font-bold mb-1 uppercase tracking-tighter">Specification</p>
                            <p class="text-sm text-slate-600 leading-snug">${i.spec}</p>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        loadData();
    </script>
</body>
</html>
